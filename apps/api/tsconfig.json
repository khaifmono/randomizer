{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
      "composite": true,
      "jsx": "react-jsx",
      "jsxImportSource": "hono/jsx",
      "baseUrl": "./",
      "paths": {
        "@/api/*": ["./src/*"]
      },
      "resolveJsonModule": true,
      "typeRoots": ["./node_modules/@types", "./node_modules/@cloudflare"],
      "types": [
        "workers-types/2023-07-01",
        "vitest-pool-workers",
        "node"
      ]
    },
    "include": [
      "src/**/*",
      "vitest.config.ts",
      "drizzle.config.ts"
    ]
  }
  