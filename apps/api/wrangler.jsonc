{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "base-project-api",
    "main": "src/app.ts",
    "compatibility_date": "2024-11-05",
    "compatibility_flags": [
      "nodejs_compat"
    ],
    "d1_databases": [
      {
        "binding": "DB",
        "database_name": "base-project-api",
        "database_id": "2db59e6d-8200-46ab-b513-2060d987a077",
        "migrations_dir": "src/db/migrations"
      }
    ]
}
